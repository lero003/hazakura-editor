{
  "name": "hazakura-editor",
  "private": true,
  "version": "1.10.0",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:vite": "vite --host 127.0.0.1 --port 1420",
    "typecheck": "tsc --noEmit",
    "build": "npm run build:app-store-preview",
    "build:tauri": "tauri build",
    "build:tauri:developer-preview": "env -u APPLE_SIGNING_IDENTITY tauri build",
    "build:tauri:app-store-preview": "env -u APPLE_SIGNING_IDENTITY tauri build --config src-tauri/tauri.conf.appstore-preview.json",
    "build:tauri:app-store-submit": "tauri build --bundles app --target universal-apple-darwin --config src-tauri/tauri.conf.appstore.json",
    "build:app-store-preview": "HAZAKURA_DISTRIBUTION_LANE=app-store VITE_HAZAKURA_DISTRIBUTION_LANE=app-store npm run build:tauri:app-store-preview",
    "build:app-store-submit": "HAZAKURA_DISTRIBUTION_LANE=app-store VITE_HAZAKURA_DISTRIBUTION_LANE=app-store npm run build:tauri:app-store-submit && node scripts/sign-app-store-submit-app.mjs",
    "build:app-store-pkg": "node scripts/build-app-store-pkg.mjs",
    "bump:app-store-build": "node scripts/bump-app-store-build-version.mjs",
    "release:candidate": "node scripts/prepare-release-candidate.mjs",
    "candidate:app-store-pkg": "node scripts/prepare-release-candidate.mjs --with-app-store-pkg",
    "build:developer-preview": "HAZAKURA_DISTRIBUTION_LANE=developer VITE_HAZAKURA_DISTRIBUTION_LANE=developer npm run build:tauri:developer-preview",
    "build:macos-lanes": "bash scripts/build-macos-lanes.sh",
    "build:apple-assist-helper:fixture": "bash scripts/build-apple-assist-helper-fixture.sh",
    "build:apple-assist-helper:live": "bash scripts/build-apple-assist-helper-live.sh",
    "build:import-assist-helper:fixture": "bash scripts/build-import-assist-helper-fixture.sh",
    "build:import-assist-helper:live": "bash scripts/build-import-assist-helper-live.sh",
    "build:dmg-preview": "bash scripts/build-warning-dmg-preview.sh",
    "build:vite": "tsc --noEmit && vite build",
    "probe:macos-distribution": "bash scripts/probe-macos-distribution.sh",
    "preview": "vite preview --host 127.0.0.1",
    "smoke:app-store-surface": "vitest run src/buildScripts.test.ts src/lib/distributionLane.test.ts src/hooks/commandPalette/useCommandPaletteController.test.ts src/hooks/agent/useAgentWorkbenchPreferences.test.ts src/components/agent/AgentWorkbenchPreferencesPane.test.tsx src/components/app/SettingsPreferencesPane.test.tsx src/components/app/AppTopChrome.test.tsx src/components/app/RightPaneToggleControls.test.tsx src/components/app/DocumentMetaBar.test.tsx src/hooks/review/useReviewDeskState.test.ts",
    "smoke:macos-window": "bash scripts/smoke-macos-window.sh",
    "smoke:macos-sandbox-preview": "bash scripts/smoke-macos-sandbox-preview.sh",
    "smoke:fixtures:v1.8-reference": "node scripts/generate-v1.8-reference-smoke.mjs",
    "smoke:fixtures:v1.10-structure": "node scripts/generate-v1.10-structure-smoke.mjs",
    "clean:generated": "node scripts/clean-generated-artifacts.mjs",
    "clean:generated:apply": "node scripts/clean-generated-artifacts.mjs --apply",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/view": "6.43.2",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.5",
    "marked": "^18.0.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "@codemirror/view": "6.43.2"
  }
}

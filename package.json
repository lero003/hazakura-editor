{
  "name": "hazakura-editor",
  "private": true,
  "version": "0.16.0",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:vite": "vite --host 127.0.0.1 --port 1420",
    "typecheck": "tsc --noEmit",
    "build": "npm run build:app-store-preview",
    "build:tauri": "tauri build",
    "build:app-store-preview": "HAZAKURA_DISTRIBUTION_LANE=app-store VITE_HAZAKURA_DISTRIBUTION_LANE=app-store npm run build:tauri",
    "build:developer-preview": "HAZAKURA_DISTRIBUTION_LANE=developer VITE_HAZAKURA_DISTRIBUTION_LANE=developer npm run build:tauri",
    "build:macos-lanes": "bash scripts/build-macos-lanes.sh",
    "build:apple-assist-helper:fixture": "bash scripts/build-apple-assist-helper-fixture.sh",
    "build:apple-assist-helper:live": "bash scripts/build-apple-assist-helper-live.sh",
    "build:dmg-preview": "bash scripts/build-warning-dmg-preview.sh",
    "build:vite": "tsc --noEmit && vite build",
    "probe:macos-distribution": "bash scripts/probe-macos-distribution.sh",
    "preview": "vite preview --host 127.0.0.1",
    "smoke:macos-sandbox-preview": "bash scripts/smoke-macos-sandbox-preview.sh",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.5",
    "marked": "^18.0.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.8"
  }
}
